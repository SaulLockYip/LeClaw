{
  "name": "@leclaw/server",
  "version": "1.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@leclaw/db": "workspace:*",
    "@leclaw/shared": "workspace:*",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.4",
    "express": "^5.2.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "playwright": "1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsc --build --force",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  }
